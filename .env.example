# social-mcp 環境變數設定
# 複製此檔案為 .env 並填入實際值

# Facebook 粉絲頁 ID（可從網址取得）
# 例如：https://www.facebook.com/MyPage → 填入 "MyPage" 或數字 ID
FACEBOOK_PAGE_ID=

# Instagram Business 帳號數字 ID（從 Meta Business Suite 取得）
# 格式：看起來像 1784140xxxxx
IG_USER_ID=

# Facebook App ID（用於 OAuth token exchange，可選）
# FB_APP_ID=1249215749037029

# Facebook App Secret（用於 OAuth token exchange，可選）
# FB_APP_SECRET=
